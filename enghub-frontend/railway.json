{
  "build": {
    "builder": "docker",
    "dockerfile": "Dockerfile"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3,
    "healthchecks": {
      "liveness": {
        "command": ["node", "-e", "require('http').get('http://localhost:3000/', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})"],
        "interval": 30,
        "timeout": 10,
        "initialDelay": 15
      }
    }
  }
}
