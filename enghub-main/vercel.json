{
  "headers": [
    {
      "source": "/agenda.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/raschety-agenda.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "functions": {
    "api/spec-export.js": {
      "includeFiles": "{api/template.xlsx,node_modules/exceljs/**}"
    },
    "api/cable-calc/parse.py": {
      "maxDuration": 60
    },
    "api/cable-calc/reverse.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ]
}