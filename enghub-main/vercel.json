{
  "functions": {
    "api/spec-export.js": {
      "includeFiles": "{api/template.xlsx,node_modules/exceljs/**}"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 8 * * 1"
    }
  ]
}
