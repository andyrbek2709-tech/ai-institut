{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "EngHub React App",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "cwd": "enghub-main",
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "EngHub Full Stack (Vercel Dev)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev"],
      "cwd": "enghub-main",
      "port": 3000,
      "autoPort": true
    }
  ]
}
