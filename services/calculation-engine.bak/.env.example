# Application
APP_NAME=Calculation Engine
DEBUG=false
API_VERSION=0.1.0

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/calculations

# Units
DEFAULT_UNIT_SYSTEM=SI
SUPPORTED_UNIT_SYSTEMS=SI,Imperial,Custom

# Templates
TEMPLATES_PATH=app/templates/data

# Calculation Limits
MAX_CALCULATION_VARIABLES=1000
MAX_CALCULATION_DEPTH=100

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
