# ============================================
# Orchestrator Service — Environment Variables
# ============================================
# For production, create .env.production with actual values
# For development/local, use docker-compose.yml with docker-compose.dev.yml

# Redis configuration
# LOCAL: redis://localhost:6379
# PROD (Upstash): rediss://default:xxxxx@xxxxx.upstash.io:xxxxx (with SSL)
REDIS_URL=rediss://default:xxxxx@xxxxx.upstash.io:xxxxx

# Supabase configuration
# Get from: https://supabase.co/dashboard/project/jbdljdwlfimvmqybzynv/settings/api
SUPABASE_URL=https://jbdljdwlfimvmqybzynv.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Orchestrator configuration
LOG_LEVEL=info
MAX_RETRIES=3
RETRY_DELAY_MS=1000
CONSUMER_GROUP_NAME=orchestrator-group

# Optional: Telegram notifications (for escalation alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
