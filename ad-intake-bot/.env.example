# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Supabase (Settings → API → service_role key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Manager Telegram Chat ID (start @userinfobot to get it)
MANAGER_CHAT_ID=

# Multi-tenant: JSON {"bot_username":{"manager_chat_id":"-100..."}} — ключ без @. Пусто = один MANAGER_CHAT_ID.
# TENANTS_JSON=

# Внешняя CRM: POST JSON лида после уведомления менеджера (Bitrix incoming webhook, n8n, …). Пусто = не слать.
# CRM_WEBHOOK_URL=
# BITRIX24_INCOMING_WEBHOOK=

# Railway public domain (assigned after deploy). Leave empty for local long-polling mode.
WEBHOOK_DOMAIN=https://your-app.up.railway.app

# Port (Railway sets this automatically)
PORT=3000
