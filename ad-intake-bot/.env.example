# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# OpenAI API Key (https://platform.openai.com/api-keys) — Whisper, эмбеддинги RAG и при отсутствии LLM_API_KEY
OPENAI_API_KEY=

# Модель эмбеддингов для knowledge_items (pgvector). По умолчанию: text-embedding-3-small (1536)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Чат-LLM (см. src/services/openai.js). По умолчанию: DeepSeek baseURL + модель deepseek-v4-flash
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash

# Supabase (Settings → API → service_role key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Отдельный проект только под бота: один раз выполните в SQL Editor файл
# supabase/bundle_ad_intake_bot_schema.sql (см. docs/SUPABASE_DEDICATED_PROJECT.md).
# Куда смотрит прод и как синхронизировать Railway: docs/PRODUCTION_CURRENT.md

# Manager Telegram Chat ID (start @userinfobot to get it)
MANAGER_CHAT_ID=

# Напоминание в чат менеджеров, если лид остался в статусе «new» (мс). По умолчанию 300000 = 5 мин. 0 = выкл.
# MANAGER_LEAD_ACTION_NUDGE_MS=300000

# Логотип для приветствия /start. По умолчанию: assets/vformate-logo-telegram.png (компактный), иначе vformate-logo.png.
# AGENCY_LOGO_PATH=/absolute/path/to/logo.png
# Пересборка PNG для чата: npm run build:telegram-logo (см. assets/README — TELEGRAM_LOGO_INNER_MAX_H, TARGET_SCREEN_H, TRIM_THRESHOLD, PAD_* …)

# User id менеджеров (через запятую) — сбор заявок в личке с ботом для них будет отключён,
# после «Уточнить» одно сообщение уйдёт клиенту. Без этого списка старое правило: кто может жать slash в группе.
# MANAGER_TELEGRAM_USER_IDS=123456789,987654321

# Multi-tenant: JSON {"bot_username":{"manager_chat_id":"-100..."}} — ключ без @. Пусто = один MANAGER_CHAT_ID.
# TENANTS_JSON=

# Внешняя CRM: POST JSON лида после уведомления менеджера (Bitrix incoming webhook, n8n, …). Пусто = не слать.
# CRM_WEBHOOK_URL=
# BITRIX24_INCOMING_WEBHOOK=

# amoCRM REST (сделка в воронке): subdomain без .amocrm.ru, long-lived access token.
# AMOCRM_SUBDOMAIN=
# AMOCRM_ACCESS_TOKEN=
# AMOCRM_PIPELINE_ID=
# AMOCRM_BASE_URL=https://subdomain.amocrm.ru   # опционально, если нестандартный домен

# Railway public domain (assigned after deploy). Leave empty for local long-polling mode.
WEBHOOK_DOMAIN=https://your-app.up.railway.app

# Port (Railway sets this automatically)
PORT=3000
