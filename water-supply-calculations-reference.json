    },
    "validation_rules": {
      "velocity_checks": [
        {"condition": "v < 0.5 m/s", "problem": "Застой, отложения в трубе", "action": "Уменьшить диаметр"},
        {"condition": "v > 1.5 m/s", "problem": "Высокий шум, абразивный износ", "action": "Увеличить диаметр"},
        {"condition": "0.5 <= v <= 1.5 m/s", "result": "OK"}
      ],
      "sewer_velocity_checks": [
        {"condition": "v < 0.6 m/s", "problem": "Самоочистка неадекватна, илование", "action": "Увеличить уклон"},
        {"condition": "v > 1.5 m/s", "problem": "Абразивный износ труб", "action": "Увеличить диаметр"},
        {"condition": "0.6 <= v <= 1.5 m/s", "result": "OK"}
      ],
      "pressure_checks": [
        {"condition": "p < 10 m ws (residential)", "problem": "Недостаточный напор на верхних этажах"},
        {"condition": "p > 60 m ws", "problem": "Избыточное давление, риск разрывов"},
        {"condition": "10-50 m ws", "result": "OK"}
      ]
    }
  }
}
