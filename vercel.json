{
  "version": 2,
  "builds": [
    {
      "src": "enghub-main/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "enghub-main/api/orchestrator.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/orchestrator",
      "dest": "/enghub-main/api/orchestrator.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/enghub-main/index.html"
    }
  ]
}
